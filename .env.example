# ============================================================
# JobCatch backend — environment contract
# Copy to `.env` for local dev. NEVER commit the real .env.
# ============================================================

# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostGIS-enabled Postgres) ---
# Format: postgis://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgis://jobcatch:jobcatch@localhost:5432/jobcatch

# --- Redis (cache, Channels layer, Celery broker) ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SIGNING_KEY=change-me-separate-from-secret-key
ACCESS_TOKEN_LIFETIME_MIN=15
REFRESH_TOKEN_LIFETIME_DAYS=14

# --- CORS (client origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:19006

# --- Email (OTP + notifications). Console backend in dev. ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@jobcatchonline.com

# --- Payment gateways (Phase 2) ---
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=

# --- Object storage (S3-compatible) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# --- AI (Phase 3) ---
LLM_PROVIDER=            # e.g. anthropic | openai (abstraction picks impl)
LLM_API_KEY=

# --- Google Maps (Phase 3 geo) ---
GOOGLE_MAPS_API_KEY=
